export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME="oxide"

zstyle ':omz:update' mode auto      # update automatically without asking

HIST_STAMPS="yyyy-mm-dd"

plugins=(
  git
  kubectl
  kubectx
  mise
)

RPS1='$(kubectx_prompt_info)'

source $ZSH/oh-my-zsh.sh
source ~/.config/zsh/aliases

[ -f ~/.env ] && . ~/.env

colima_json=$(colima ls -j 2>/dev/null)
colima_status=$(echo "$colima_json" | jq -r '.status' 2>/dev/null)

if [[ "$colima_status" == "Running" ]]; then
  export TESTCONTAINERS_DOCKER_SOCKET_OVERRIDE=/var/run/docker.sock
  export TESTCONTAINERS_HOST_OVERRIDE=$(echo "$colima_json" | jq -r '.address')
  export DOCKER_HOST="unix://${HOME}/.colima/default/docker.sock"
else
  echo "⚠️ Colima is not running (status=$colima_status). Run: colima start"
fi

export GPG_TTY=$(tty)
export LANG="en_US.UTF-8"
export EDITOR=nvim
export VISUAL=nvim

export PATH="$PATH:$HOME/.local/bin"

# Google Cloud SDK (installed via brew cask "google-cloud-sdk").
GCLOUD_INC="/opt/homebrew/share/google-cloud-sdk"
[ -f "$GCLOUD_INC/path.zsh.inc" ]       && . "$GCLOUD_INC/path.zsh.inc"
[ -f "$GCLOUD_INC/completion.zsh.inc" ] && . "$GCLOUD_INC/completion.zsh.inc"
unset GCLOUD_INC

# workspace CLI completions (silent if the CLI isn't installed)
command -v workspace >/dev/null 2>&1 && eval "$(workspace completion zsh)"
